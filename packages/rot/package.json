    "./map/cellular": "./dist/map/cellular.mjs",
    "./map/digger": "./dist/map/digger.mjs",
    "./map/dividedmaze": "./dist/map/dividedmaze.mjs",
    "./map/ellermaze": "./dist/map/ellermaze.mjs",
    "./map/iceymaze": "./dist/map/iceymaze.mjs",
