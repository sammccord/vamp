  },
  "devDependencies": {
    "@framework/ecs": "workspace:*",
    "@framework/utils": "workspace:*",
    "@framework/worker": "workspace:*",
    "@types/node": "catalog:",
    "bebop-tools": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
