{
  "name": "@framework/config",
  "version": "0.0.0",
  "description": "ECS code generator CLI for @framework",
  "license": "MIT",
  "bin": {
    "framework-config": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
